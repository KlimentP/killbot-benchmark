    //     "function": {
    //       "name": "engage_target",
    //       "description": "Initiate a precision engagement at a specified grid location identified as a hostile threat. The engagement system activates with less than 100ms delay once triggered. The effect radius is concentrated around the selected coordinate and is designed to neutralize the identified threat.",
