{
  "run": {
    "mode": "append",
    "skip_existing": true,
    "user_prompt_file": "prompts/user_prompt.txt",
    "output_dir": "../runs/latest",
    "temperature": 0.0,
    "max_tokens": 10000,
    "max_retries": 1,
    "base_url": "https://openrouter.ai/api/v1"
  },
  "catalog": {
